{
  "name": "oiseau-blanc-server",
  "version": "1.0.0",
  "description": "Backend Express + TypeScript - L'Oiseau Blanc Traiteur",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-client": "tsx prisma/seed-client.ts",
    "db:export-ovh": "tsx scripts/export-mysql.ts",
    "db:schema-ovh": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/ovh/schema.sql",
    "db:build-ovh": "tsx scripts/build-import.ts",
    "push:generate-keys": "tsx scripts/generate-vapid.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "pg": "^8.22.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
