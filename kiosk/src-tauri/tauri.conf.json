{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Friggo Borne",
  "version": "0.2.0",
  "identifier": "fr.oiseaublanc.kiosk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Friggo Borne",
        "width": 1280,
        "height": 800,
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://164.132.96.144.sslip.io/updates/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2QjEzNjRFMjU5OEY3NUMKUldSYzk1Z2xUamF4MWpXVXFTajdnRUluRzlaVnJXelJ6SktWdzBFVnZzaGU1R2s4dUtGRStHR04K"
    }
  }
}
