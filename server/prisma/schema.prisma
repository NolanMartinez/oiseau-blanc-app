generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  LIVREUR
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("administrateurs")
}

model Subscriber {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?
  passwordHash        String?   @map("password_hash")
  favoriId            String?   @map("favori_id")
  notificationsSeenAt DateTime? @map("notifications_seen_at")
  consentEmail Boolean  @default(false) @map("consent_email")
  consentPush  Boolean  @default(false) @map("consent_push")
  pushToken    String?  @map("push_token") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  reviews             Review[]
  preferenceResponses PreferenceResponse[]
  menuVoteResponses   MenuVoteResponse[]
  purchases           Purchase[]

  @@map("abonnes")
}

model Review {
  id           String     @id @default(uuid())
  subscriberId String     @map("subscriber_id")
  dishId       String     @map("dish_id")
  rating       Int
  comment      String?    @db.Text
  createdAt    DateTime   @default(now()) @map("created_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id])

  @@map("avis")
}

model PreferenceSurvey {
  id        String   @id @default(uuid())
  title     String
  questions Json
  active    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  responses PreferenceResponse[]

  @@map("sondages")
}

model PreferenceResponse {
  id         String           @id @default(uuid())
  surveyId   String           @map("survey_id")
  subscriberId String         @map("subscriber_id")
  answers    Json
  createdAt  DateTime         @default(now()) @map("created_at")

  survey     PreferenceSurvey @relation(fields: [surveyId], references: [id])
  subscriber Subscriber       @relation(fields: [subscriberId], references: [id])

  @@map("reponses_sondages")
}

model MenuVote {
  id           String   @id @default(uuid())
  title        String
  options      Json
  voteDeadline DateTime @map("vote_deadline")
  createdAt    DateTime @default(now()) @map("created_at")

  responses MenuVoteResponse[]

  @@map("votes_menus")
}

model MenuVoteResponse {
  id              String   @id @default(uuid())
  menuVoteId      String   @map("menu_vote_id")
  subscriberId    String   @map("subscriber_id")
  selectedOptions Json     @map("selected_options")
  createdAt       DateTime @default(now()) @map("created_at")

  menuVote   MenuVote   @relation(fields: [menuVoteId], references: [id])
  subscriber Subscriber @relation(fields: [subscriberId], references: [id])

  @@map("reponses_votes_menus")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String   @db.Text
  url       String   @default("/app/mon-frigo")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model OtpCode {
  id        String   @id @default(uuid())
  contact   String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([contact])
  @@map("codes_otp")
}

model Purchase {
  id           String     @id @default(uuid())
  subscriberId String     @map("subscriber_id")
  dishId       String     @map("dish_id")
  frigoId      String     @map("frigo_id")
  purchasedAt  DateTime   @default(now()) @map("purchased_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@map("achats")
}

model Dish {
  id            String   @id @default(uuid())
  name          String
  category      String
  description   String?  @db.Text
  price         Float
  allergens     Json
  dlcDays       Int?     @map("dlc_days")
  imageData     Bytes?   @map("image_data") @db.LongBlob
  imageMimeType String?  @map("image_mime_type")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  fridgeStocks FridgeStock[]
  translations DishTranslation[]

  @@map("plats")
}

model DishTranslation {
  id          String   @id @default(uuid())
  dishId      String   @map("dish_id")
  language    String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([dishId, language])
  @@index([dishId])
  @@map("traductions_plats")
}

model FridgeStock {
  id           String    @id @default(uuid())
  frigoId      String    @map("frigo_id")
  dishId       String    @map("dish_id")
  quantity     Int       @default(0)
  expiryDate   DateTime? @map("expiry_date")
  promoPercent Int?      @map("promo_percent")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@unique([frigoId, dishId])
  @@index([dishId])
  @@map("stocks_frigos")
}

model Fridge {
  id           String   @id @default(uuid())
  name         String
  serialNumber String?  @map("serial_number")
  location     String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("frigos")
}

model Sale {
  id      String   @id @default(uuid())
  frigoId String   @map("frigo_id")
  dishId  String   @map("dish_id")
  amount  Int // centimes
  mode    String   @default("paid") // paid | free
  soldAt  DateTime @default(now()) @map("sold_at")

  @@index([frigoId])
  @@index([soldAt])
  @@map("ventes")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}
